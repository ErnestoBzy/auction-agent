# ============================================================
# Template for local configuration.
# Usage: copy this file to `.env` and replace all {{...}} placeholders
# with real values. The real `.env` is git-ignored and must never
# be committed. All placeholders are documented in CONFIG.md.
# ============================================================

# Base URL of the auction platform (no trailing slash)
PLATFORM_BASE_URL={{PLATFORM_BASE_URL}}

# n8n webhook (production URL, not the test URL) — only needed for the n8n path
WEBHOOK_URL={{WEBHOOK_URL}}

# Platform fee model
# PLATFORM_PREMIUM: buyer's premium as a fraction (e.g. 0.10 for 10%)
# PLATFORM_FIXED_FEE: fixed transaction fee per purchase (in the respective currency)
PLATFORM_PREMIUM={{PLATFORM_PREMIUM}}
PLATFORM_FIXED_FEE={{PLATFORM_FIXED_FEE}}

# Google Gemini (rating without grounding)
GOOGLE_API_KEY={{GOOGLE_API_KEY}}
GOOGLE_SCORING_MODEL=gemini-2.5-flash-lite    # rating without grounding
GOOGLE_MAX_RETRIES=5                           # retries on 429/503
GOOGLE_BACKOFF_BASE_SEC=4                       # base backoff seconds on retry
REQUEST_GAP_SEC=1.5                             # pause between API calls

# Cost control
# Platform estimates are typically 10-20% above market value → correction factor
# 0.85 = 15% discount (default). Range: 0.80–0.90
ESTIMATE_FACTOR=0.85

# DuckDuckGo + cache
DDG_GAP_SEC=2.0                                # pause between DDG requests (rate limiting)
CACHE_TTL_DAYS=7                               # cache validity in days
DDG_BROWSER_TIMEOUT_SEC=20                     # timeout for DDG browser verification
DDG_BROWSER_GAP_SEC=3.0                        # pause between browser verifications

# Notion: active auctions DB
NOTION_TOKEN={{NOTION_TOKEN}}
NOTION_DB_ID={{NOTION_DB_ID}}

# Notion: sales history DB (separate token with access to the history DB)
NOTION_TOKEN2={{NOTION_TOKEN2}}
NOTION_HISTORY_DB_ID={{NOTION_HISTORY_DB_ID}}
